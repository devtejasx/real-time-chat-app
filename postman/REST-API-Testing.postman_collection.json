      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('content-type is json', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "pm.test('responds quickly', () => pm.expect(pm.response.responseTime).to.be.below(2000));",
                  "const j = pm.response.json();",
                  "pm.test('envelope is success', () => { pm.expect(j.success).to.be.true; pm.expect(j).to.have.property('data'); });",
                  "pm.test('status ok', () => pm.expect(j.data.status).to.eql('ok'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        }
      ]
    },
