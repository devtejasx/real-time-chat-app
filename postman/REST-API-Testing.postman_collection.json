                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('regEmail', `qa_${Date.now()}@rats.dev`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('content-type is json', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "pm.test('responds quickly', () => pm.expect(pm.response.responseTime).to.be.below(2000));",
                  "const j = pm.response.json();",
                  "pm.test('envelope success', () => pm.expect(j.success).to.be.true);",
                  "pm.test('returns a token', () => pm.expect(j.data.token).to.be.a('string').and.not.empty);",
                  "pm.test('returns the user', () => { pm.expect(j.data.user).to.have.property('id'); pm.expect(j.data.user.email).to.eql(pm.collectionVariables.get('regEmail')); });",
                  "pm.test('never leaks password', () => pm.expect(j.data.user).to.not.have.property('password'));"
                ]
              }
            }
          ],
